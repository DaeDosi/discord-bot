# ── 봇 설정 ─────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
OWNER_ID=your_discord_user_id_here

# ── OAuth2 (웹 대시보드) ─────────────────────────────────
DISCORD_CLIENT_ID=your_application_client_id
DISCORD_CLIENT_SECRET=your_application_client_secret
DISCORD_REDIRECT_URI=http://localhost:3000/callback

# ── JWT 시크릿 (랜덤 문자열로 변경) ──────────────────────
JWT_SECRET=change-this-to-a-random-secret-string

# ── 데이터베이스 ──────────────────────────────────────────
DATABASE_URL=sqlite:///./bot.db

# ── Chzzk ────────────────────────────────────────────────
CHZZK_POLL_INTERVAL=60

# ── 네이버 OAuth (치지직 인증용) ──────────────────────────
# https://developers.naver.com 에서 앱 등록 후 발급
# 콜백 URL 등록: http://localhost:8000/api/chzzk-auth/callback
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:8000/api/chzzk-auth/callback
